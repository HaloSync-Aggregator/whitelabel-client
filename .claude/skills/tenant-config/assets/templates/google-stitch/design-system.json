    "accentOrange": "#F97316",
    "text": {
      "primary": "#0F172A",
      "secondary": "#64748B",
      "tertiary": "#94A3B8"
    },
    "background": {
      "primary": "#FFFFFF",
      "secondary": "#F9FAFB",
      "tertiary": "#F8FAFC"
    },
    "border": {
      "light": "#E5E7EB",
      "dark": "#CBD5E1"
    },
    "status": {
