{
  "permissions": {
    "allow": [
      "Task",
      "Write",
      "Edit",
      "Bash(*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && python3 .claude/hooks/protect_sensitive_files.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && python3 .claude/hooks/py_compile_after_edit.py"
          }
        ]
      }
    ]
  }
}
