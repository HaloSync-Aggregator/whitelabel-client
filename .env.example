# ----------------------------------
# Frontend Runtime Configuration
# ----------------------------------
# URL of your whitelabel-middleware instance for local development.
# Leave empty in production if /middleware/* is served from the same origin.
VITE_MIDDLEWARE_URL=http://localhost:3000

# Base path for SPA deployment. Use "/" for local dev or root hosting.
VITE_BASE_PATH=/

# This frontend repo does not require PolarHub API credentials directly.
# Configure airline/PolarHub secrets in the middleware repository instead.
